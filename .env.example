# ============================================
# 가드이어 환경 변수 템플릿
# 사용법: 값 채운 후 .env 로 저장하거나, export/set 명령어로 주입
# .env 파일은 .gitignore에 포함되어 있으니 커밋되지 않습니다.
# ============================================

# --- Gmail SMTP (이메일 알림) ---
# Gmail 계정 > 보안 > 2단계 인증 > 앱 비밀번호 발급
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-digit-app-password

# --- NHN Cloud SMS (문자 알림) ---
# NHN Cloud 콘솔 > Notification > SMS 에서 발급
NHN_APP_KEY=your-app-key
NHN_SECRET_KEY=your-secret-key
NHN_SENDER_NUMBER=01012345678
